<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#121212">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <ImageView
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:src="@drawable/ic_launcher"
            android:scaleType="fitCenter"
            android:layout_marginRight="12dp"
            android:contentDescription="PromptSlutette Icon" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PromptSlutette Panel"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Port: "
            android:textColor="#CCCCCC"
            android:textSize="16sp" />

        <EditText
            android:id="@+id/etPort"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:text="8080"
            android:textColor="#FFFFFF"
            android:backgroundTint="#FFFFFF" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Context Size: "
            android:textColor="#CCCCCC"
            android:textSize="16sp" />

        <Spinner
            android:id="@+id/spContextSize"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#FFFFFF" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Model GGUF File Path (Download Folder):"
        android:textColor="#CCCCCC"
        android:textSize="14sp"
        android:layout_marginBottom="4dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <EditText
            android:id="@+id/etModelPath"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="/storage/emulated/0/Download/model.gguf"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:backgroundTint="#FFFFFF" />

        <Button
            android:id="@+id/btnBrowseModel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Browse"
            android:backgroundTint="#FF6200EE"
            android:textColor="#FFFFFF" />
    </LinearLayout>

    <CheckBox
        android:id="@+id/cbMtp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Enable MTP Speculative Decoding"
        android:textColor="#FFFFFF"
        android:buttonTint="#FFBB86FC"
        android:layout_marginBottom="4dp" />

    <CheckBox
        android:id="@+id/cbNgram"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Enable N-Gram Speculative Decoding"
        android:textColor="#FFFFFF"
        android:buttonTint="#FFBB86FC"
        android:layout_marginBottom="4dp" />

    <CheckBox
        android:id="@+id/cbDisableReasoning"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Disable Reasoning/Thinking (budget=0)"
        android:textColor="#FFFFFF"
        android:buttonTint="#FFBB86FC"
        android:layout_marginBottom="8dp" />

    <CheckBox
        android:id="@+id/cbFlashAttn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Enable Flash Attention (Recommended)"
        android:textColor="#FFFFFF"
        android:checked="true"
        android:buttonTint="#FFBB86FC"
        android:layout_marginBottom="16dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <Button
            android:id="@+id/btnStart"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Start Server"
            android:backgroundTint="#FF018786"
            android:textColor="#FFFFFF"
            android:layout_marginRight="8dp" />

        <Button
            android:id="@+id/btnStop"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Stop Server"
            android:backgroundTint="#D32F2F"
            android:textColor="#FFFFFF" />
    </LinearLayout>

    <Button
        android:id="@+id/btnOpenWeb"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Open Web UI in Browser"
        android:backgroundTint="#FF6200EE"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="16dp"
        android:visibility="visible" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Server Console Output:"
        android:textColor="#CCCCCC"
        android:textSize="14sp"
        android:layout_marginBottom="4dp" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#1E1E1E"
        android:padding="8dp">

        <ScrollView
            android:id="@+id/scrollLog"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <TextView
                android:id="@+id/tvLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Server is not running.\n"
                android:textColor="#00FF00"
                android:fontFamily="monospace"
                android:textSize="12sp" />
        </ScrollView>
    </FrameLayout>

</LinearLayout>
